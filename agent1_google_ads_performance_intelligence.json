                      "parameters":  {
                                         "method":  "POST",
                                         "url":  "=https://googleads.googleapis.com/v18/customers/{{ $json.customerId }}/googleAds:search",
                                         "authentication":  "predefinedCredentialType",
                                         "nodeCredentialType":  "googleAdsOAuth2Api",
                                         "sendHeaders":  true,
                                         "headerParameters":  {
                                                                  "parameters":  [
