                                         "sendBody":  true,
                                         "specifyBody":  "json",
                                         "jsonBody":  "={\"query\": \"SELECT campaign.id, campaign.name, segments.date, metrics.impressions, metrics.clicks, metrics.cost_micros, metrics.conversions, metrics.ctr, metrics.average_cpc, metrics.search_impression_share, metrics.search_budget_lost_impression_share FROM campaign WHERE segments.date DURING LAST_14_DAYS AND campaign.status != \u0027REMOVED\u0027\"}",
