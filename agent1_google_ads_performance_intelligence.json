                  {
                      "parameters":  {
                                         "jsCode":  "const analyze = $(\u0027Analyze — Output A (table) + anomalies\u0027).first().json;\nconst table = analyze.performanceTableMarkdown || \u0027(aucune ligne)\u0027;\nconst claude = $input.first().json;\nconst narrative = claude.content \u0026\u0026 claude.content[0] ? claude.content[0].text : JSON.stringify(claude);\nconst d = new Date();\nconst iso = d.toISOString().slice(0, 10);\nconst body = [\n  \u0027A – Analyse de performance automatisée (synthèse structurée)\u0027,\n  \u0027\u0027,\n  \u0027Tableau : Campagne, CPA, Delta, CTR, CVR, IS Lost, Anomalie, Statut (aligné page produit Automation Act).\u0027,\n  \u0027\u0027,\n  table,\n  \u0027\u0027,\n  \u0027---\u0027,\n  \u0027\u0027,\n  \u0027B – Performance Intelligence Report\u0027,\n  \u0027\u0027,\n  narrative,\n].join(\u0027\\n\u0027);\nreturn [{ json: { subject: \u0027Performance Intelligence Report — \u0027 + iso, body } }];"
                                     },
